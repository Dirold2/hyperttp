{
  "name": "hyperttp",
  "version": "0.2.5",
  "description": "A high-performance, universal HTTP client for Node.js with caching, retries, queueing, rate limiting, cookies and logging.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirold2/hyperttp.git"
  },
  "keywords": [
    "http",
    "client",
    "fetch",
    "undici",
    "cache",
    "rate-limit",
    "queue",
    "retry",
    "cookies",
    "logger"
  ],
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.8.0",
    "http-cookie-agent": "^8.0.0",
    "lru-cache": "^11.3.6",
    "tough-cookie": "^6.0.1",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "4.1.6",
    "chalk": "5.6.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "jiti": "^2.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write .",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  }
}
