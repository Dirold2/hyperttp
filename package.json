{
  "name": "hyperttp",
  "version": "0.4.9",
  "description": "A high-performance, universal HTTP client for Node.js, Bun, Deno and Browser with caching, retries, queueing, rate limiting, cookies and logging.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "http",
    "client",
    "fetch",
    "undici",
    "cache",
    "rate-limit",
    "queue",
    "retry",
    "cookies",
    "logger",
    "bun",
    "deno",
    "isomorphic",
    "hyperttp"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirold2/hyperttp.git"
  },
  "dependencies": {
    "@hyperttp/cache": "^1.1.6",
    "@hyperttp/core": "^1.4.8",
    "@hyperttp/inflight": "^1.1.6",
    "@hyperttp/interceptors": "^1.1.5",
    "@hyperttp/metrics": "^1.2.0",
    "@hyperttp/parser": "^1.1.8",
    "@hyperttp/queue": "^1.1.5",
    "@hyperttp/ratelimit": "^1.1.5",
    "@hyperttp/serializer": "^1.2.0",
    "@hyperttp/types": "^0.2.4"
  },
  "devDependencies": {
    "@dirold2/dev-tools": "^1.0.16",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "jiti": "^2.7.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsc && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  }
}
